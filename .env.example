# NewsMind Trading System — environment template.
# Copy this file to .env and fill in real values.
# .env MUST be in .gitignore — never commit your real keys.

# ----- LLM (OpenAI) ------------------------------------------------
# Required when ENABLE_LLM=true (or auto and you want LLM thinking on).
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: pin a specific model. Default is gpt-5 set in EngineConfig.
# LLM_MODEL=gpt-5

# Optional override. "auto" enables LLM iff OPENAI_API_KEY is set.
# ENABLE_LLM=auto

# Optional: "en" or "ar" — language for SmartNoteBook lesson headlines
# inside brain prompts.
# INJECTION_LANGUAGE=en

# ----- OANDA (live broker + bar feed) ------------------------------
# Required when ENABLE_OANDA=true (or auto). Use the practice account
# first — Live trading hits real money.
OANDA_API_TOKEN=REPLACE_ME
OANDA_ACCOUNT_ID=101-001-XXXXXXXX-001
OANDA_ENVIRONMENT=practice                # "practice" or "live"
# OANDA_GRANULARITY=M15
# ENABLE_OANDA=auto

# ----- Telegram (GateMind notifications) ---------------------------
# Optional. When unset, GateMind silently skips sending fills/closes.
# TELEGRAM_TOKEN=
# TELEGRAM_CHAT_ID=

# ---