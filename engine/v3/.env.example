# Engine V3 — Live Validation Environment Variables
# Copy to .env on VPS, chmod 600, NEVER commit to git

# OANDA — start with practice, NEVER live until validation passes
OANDA_API_KEY=YOUR_NEW_KEY_AFTER_REVOKE
OANDA_ACCOUNT_ID=YOUR_ACCOUNT_ID
OANDA_ENV=practice                 # practice|live (must be practice for first validation)

# Risk caps (HARD limits — enforced by Engine, cannot be exceeded at runtime)
RISK_PCT_PER_TRADE=0.25           # 0.25% during validation. NEVER >0.5% in this phase.
MAX_RISK_PCT_PER_TRADE=0.5        # absolute ceiling — EngineV3 refuses anything higher
DAILY_LOSS_LIMIT_PCT=2.0          # halt for the day if -2% reached
CONSECUTIVE_LOSSES_LIMIT=2        # stop after 2 losses in a row
DAILY_TRADE_LIMIT=5               # max 5 trades/day during validation

# Spread / slippage limits (cancel trade if exceeded)
MAX_SPREAD_PIPS_EURUSD=1.5
MAX_SPREAD_PIPS_USDJPY=2.0
MAX_SLIPPAGE_PIPS=2.0

# Pair status (must match GateMind PAIR_STATUS)
PAIR_EUR_USD=production
PAIR_USD_JPY=monitoring
PAIR_GBP_USD=disabled

# Optional: telegram alerts (separate from trading)
TELEGRAM_TOKEN=YOUR_NEW_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# Logging
LOG_LEVEL=INFO
SMARTNOTEBOOK_DIR=/opt/newsmind/notebook
